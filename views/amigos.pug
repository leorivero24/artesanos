doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Amigos - Artesanos.com

    // Estilos y fuentes
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet")
    link(href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/css/dashboard.css")
    link(rel="icon" href="/uploads/icon.png" type="image/png")

  body
    // Navbar
    include includes/navbar.pug

    // ======================
    // 📦 CONTENIDO PRINCIPAL
    // ======================
    .container.mt-4
      .row.justify-content-center

        // 🔲 COLUMNA CENTRAL
        .col-md-5

          // 🔍 Buscador
          .mb-3
            form#searchForm.d-flex
              input#searchInput.form-control.me-2(
                type="search"
                placeholder="Buscar Seguidores..."
              )
              button.btn.btn-outline-secondary(type="submit")
                <i class="fa-solid fa-magnifying-glass-arrow-right" style="color: rgb(248, 102, 4);"></i>

          // 🔎 Resultados
          .card.mb-3.p-3
            h6.text-center Resultados de búsqueda:
            #searchResults.list-group

          // 👥 Seguidores
          .card.mb-3.p-3
            h6.text-center
              i.fa-solid.fa-people-arrows.me-1(style="color: rgb(248, 102, 4);")
              | Seguidores (
              span#seguidoresContador 0
              | )

            ul#amigos-list
            

    // ======================
    // 🔔 TOAST
    // ======================
    #toastContainer.position-fixed.bottom-0.end-0.p-3(style="z-index: 9999")
      #respuestaToast.toast(role="alert" aria-live="assertive" aria-atomic="true")
        .toast-header
          strong.me-auto Notificación
          small.text-muted ahora
          button.btn-close(type="button" data-bs-dismiss="toast")
        .toast-body
          span#toastMessage Aquí se mostrará la respuesta

    // ======================
    // 📜 SCRIPTS
    // ======================
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    script(src="/socket.io/socket.io.js")
    script(src="/js/navbar.js")
    script(src="/js/seguidores.js")
    script(src="/js/amigos.js")