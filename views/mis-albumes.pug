doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Mis Álbumes - Artesanos.com

    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet")
    link(rel="stylesheet", href="/css/mis-albumes.css")
    link(rel="icon", href="/uploads/icon.png", type="image/png")

  body
    include includes/navbar.pug

    .container-md.mt-4
      h2.text-center.mb-4 Mis Álbumes

      // 🔍 BUSCADOR
      .row.mb-4
        .col-md-5.offset-md-6
          form#formBusquedaMisAlbumes.d-flex
            input.form-control(
              type="text"
              name="query"
              placeholder="Buscar Álbumes por #Tags o Título..."
              style="max-width: 400px;"
            )
            button.btn.ms-2(
              type="submit"
              style="background-color: #6f4e37; color: white;"
            ) Buscar

      .row.justify-content-center.align-items-start

        // ======================
        // 📁 CREAR ÁLBUM
        // ======================
        .col-md-3
          .card.p-3.mb-2(style="background-color: #d9cbb6")
            h5.text-center.mb-3 Crear álbum

            form#formCrearAlbum(enctype="multipart/form-data")

              .mb-3
                label.form-label(for="visibilidadAlbum") Visibilidad
                select#visibilidadAlbum.form-select(name="visibilidad")
                  option(value="solo_seguidores" selected) Seguidores (Por defecto)
                  option(value="privada") Solo vos (Privada)
                  option(value="compartida") Personalizada...

              .mb-3.d-none#usuariosCompartidosAlbumContainer
                label.form-label Seleccioná usuarios:
                #usuariosCheckboxListAlbum
                  p.text-muted.small Cargando usuarios...

              .mb-3
                label.form-label(for="tituloAlbum") Título del álbum
                input#tituloAlbum.form-control(
                  type="text"
                  name="titulo"
                  
                  maxlength="100"
                )

              .mb-3
                label.form-label(for="imagenesAlbum") Imágenes (máx. 20)
                input#imagenesAlbum.form-control(
                  type="file"
                  name="imagenes"
                  accept="image/*"
                  multiple
                  
                )

              .mb-3
                label.form-label(for="tagsAlbum") #Tags
                input#tagsAlbum.form-control(
                  type="text"
                  name="tags"
                  placeholder="ej: cuero, madera"
                )

              button#btnCrearAlbum.btn.btn-success(type="submit")
                | Crear álbum

          // 🔔 TOAST FUERA DEL FORM (PERO PEGADO AL BOTÓN)
          #respuestaToast.toast.mt-2.ms-5(role="alert" aria-live="assertive" aria-atomic="true")
            .toast-header
              strong.me-auto Notificación
              small.text-muted ahora
              button.btn-close(
                type="button"
                data-bs-dismiss="toast"
                aria-label="Cerrar"
              )

            .toast-body
              span#toastMessage Aquí se mostrará la respuesta

        // ======================
        // 📁 LISTADO ÁLBUMES
        // ======================
        .col-md-8
          #albumesContainer
            p.text-muted.text-center Cargando álbumes...

    // ======================
    // 📦 MODAL DENUNCIA
    // ======================
    #modalDenuncia.modal.fade(tabindex="-1" aria-labelledby="modalDenunciaLabel" aria-hidden="true")
      .modal-dialog.modal-dialog-centered
        .modal-content.custom-modal-color
          form#formDenuncia

            .modal-header
              h5#modalDenunciaLabel.modal-title Denunciar contenido
              button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Cerrar")

            .modal-body
              input(type="hidden" id="denunciaTipo" name="tipo")
              input(type="hidden" id="denunciaId" name="elementoId")

              label.form-label(for="motivo") Motivo
              select#motivo.form-select(name="motivo")
                option(value="contenido_ofensivo") Ofensivo
                option(value="spam") Spam
                option(value="contenido_inapropiado") Inapropiado
                option(value="otro") Otro

              label.mt-2.form-label(for="detalle") Detalle
              textarea#detalle.form-control(
                name="detalle"
                rows="3"
                placeholder="Describe el problema..."
              )

              span#mensajeDenuncia.text-success.d-none.mt-2

            .modal-footer
              button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
              button#btnConfirmarDenuncia.btn.btn-danger(type="button") Enviar

    // ======================
    // 📜 SCRIPTS
    // ======================
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    script(src="/socket.io/socket.io.js")
    script(src="/js/navbar.js")
    script(src="/js/mis-albumes.js")