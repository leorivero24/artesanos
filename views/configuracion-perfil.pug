doctype html
html(lang="es")
  head
    title Perfil de usuario - Artesanos.com
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet")
    link(href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet")
    link(rel="stylesheet", href="/css/configuracion-perfil.css")
    link(rel="stylesheet", href="/css/dashboard.css")
    link(rel="icon", href="/uploads/icon.png", type="image/png")

  body
    // Incluir la navbar desde includes/navbar.pug
    include includes/navbar.pug

    div(style='margin-top: 70px;')

    .container.mt-5
      h2.mb-4

      .row
        // Formulario de perfil
        .col-md-6
          h4.mb-3.text-center Configuración de perfil
          form#formEditarPerfil(method='POST', action='/api/perfil', enctype='multipart/form-data', class='card p-4 shadow-sm')
            .mb-3
              label.form-label(for='inputNombre') Nombre
              input#inputNombre.form-control(type='text', name='nombre')
              div.text-danger.mt-1#errorNombre(style='display:none;')

            .mb-3
              label.form-label(for='inputApellido') Apellido
              input#inputApellido.form-control(type='text', name='apellido')
              div.text-danger.mt-1#errorApellido(style='display:none;')

            .mb-3
              label.form-label Email (no editable)
              input#inputEmail.form-control(type='email', name='email', readonly)

            .mb-3
              label.form-label(for='inputIntereses') Intereses
              textarea#inputIntereses.form-control(name='intereses', rows='2')
              div.text-danger.mt-1#errorIntereses(style='display:none;')

            .mb-3
              label.form-label(for='inputAntecedentes') Antecedentes
              textarea#inputAntecedentes.form-control(name='antecedentes', rows='2')
              div.text-danger.mt-1#errorAntecedentes(style='display:none;')

            button.btn.btn-primary.mt-3(type='submit') Guardar datos del perfil

          // Toast para datos del perfil
          div#toastContainerDatos.toastContainer.mt-3.ms-2
            div#liveToastDatos.toast(role='alert', aria-live='assertive', aria-atomic='true', data-bs-delay='3000')
              div.toast-header
                strong.me-auto Mensaje
                small.text-muted Ahora
                button.btn-close(type='button', data-bs-dismiss='toast', aria-label='Cerrar')
              div.toast-body

        // Formulario de contraseña
        .col-md-6
          h4.mb-3.text-center Configuración de contraseña
          form#formCambiarPassword(method='POST', action='/api/perfil/password', class='card p-4 shadow-sm')
            .mb-3
              label.form-label(for='inputPasswordNueva') Nueva contraseña
              input#inputPasswordNueva.form-control(type='password', name='passwordNueva', autocomplete='new-password', autocorrect='off', autocapitalize='off', spellcheck='false')
              div.text-danger.mt-1#errorNuevaPassword(style='display:none;')

            .mb-3
              label.form-label(for='inputPasswordConfirmar') Repetir contraseña
              input#inputPasswordConfirmar.form-control(type='password', name='passwordConfirmar', autocomplete='new-password', autocorrect='off', autocapitalize='off', spellcheck='false')
              div.text-danger.mt-1#errorRepetirPassword(style='display:none;')

            div.text-danger.mt-1#errorGeneral(style='display:none;')
            button.btn.btn-warning.mt-3(type='submit') Cambiar contraseña

          // Toast para contraseña
          div#toastContainer.toastContainer.mt-3.ms-2
            div#liveToast.toast(role='alert', aria-live='assertive', aria-atomic='true', data-bs-delay='3000')
              div.toast-header
                strong.me-auto Mensaje
                small.text-muted Ahora
                button.btn-close(type='button', data-bs-dismiss='toast', aria-label='Cerrar')
              div.toast-body

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')
    script(src='/js/configuracion-perfil.js')
