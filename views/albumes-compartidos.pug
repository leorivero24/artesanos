doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Albumes Compartidos - Artesanos.com

    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet")
    link(rel="stylesheet", href="/css/mis-albumes.css")
    link(rel="icon", href="/uploads/icon.png", type="image/png")
    
  body
    include includes/navbar.pug

    .container-md.mt-4
      h2.text-center.mb-4 Álbumes Compartidos

      // 🔍 Buscador alineado a la derecha
      .row.mb-4
        .col-md-5.offset-md-5
          form#formBusquedaMisAlbumes.d-flex
            input.form-control(type="text" name="query" placeholder="Buscar Álbumes por #Tags o Título..." style="max-width: 400px;")
            button.btn.ms-2(type="submit" style="background-color: #6f4e37; color: white;") Buscar
          
      .row.justify-content-center.align-items-start
        
        // Columna derecha: Contenedor de álbumes
        .col-md-8
          #albumesContainer
            p.text-muted.text-center Cargando álbumes...

    // Modal Denuncia
    div#modalDenuncia.modal.fade(tabindex="-1" aria-labelledby="modalDenunciaLabel" aria-hidden="true")
      div.modal-dialog.modal-dialog-centered
        div.modal-content.custom-modal-color
          form#formDenuncia
            div.modal-header
              h5#modalDenunciaLabel.modal-title Denunciar contenido
              button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Cerrar")
            div.modal-body
              input(type="hidden" id="denunciaTipo" name="tipo")
              input(type="hidden" id="denunciaId" name="elementoId")
              label(for="motivo") Motivo de la denuncia
              select#motivo.form-select
                option(value="contenido_ofensivo") Contenido ofensivo
                option(value="spam") Spam o publicidad no deseada
                option(value="contenido_inapropiado") Contenido inapropiado
                option(value="otro") Otro
              label.mt-2(for="detalle") Detalle (opcional)
              textarea#detalle.form-control(rows="3" placeholder="Describe el problema o agrega detalles adicionales...")
              br
              span#mensajeDenuncia.text-success.d-none.mt-2
            div.modal-footer
              button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
              button#btnConfirmarDenuncia.btn.btn-danger(type="button") Enviar denuncia

    // Scripts
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    script(src="/socket.io/socket.io.js")
    script(src="/js/navbar.js")
    script(src="/js/albumes-compartidos.js")
