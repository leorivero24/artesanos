  
  

doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Inicio - Artesanos.com

    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet")
    link(href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/css/dashboard.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
    link(rel="icon", href="/uploads/icon.png", type="image/png")

  body
    // ✅ Navbar separada
    include includes/navbar.pug

    .container.mt-4
      .row.justify-content-center
        // DERECHA: Perfil + Crear publicación
        .col-md-4
          .card.mb-3.p-3.text-center(style="background-color: #d9cbb6")
            - var avatarUrl = (usuario && usuario.imagen_perfil) ? '/uploads/' + usuario.imagen_perfil : '/uploads/default-avatar.png'
            img#sidebarUserAvatar(src=avatarUrl class="rounded-circle mb-1" alt="Avatar" width="100")
            h5#sidebarUserName Usuario Apellido
            hr
            .d-flex.justify-content-between.text-muted.small
              span Siguiendo: <span id="countSiguiendo">0</span>
              span Seguidores: <span id="countSeguidores">0</span>
              span Publicaciones: <span id="countPublicaciones">0</span>
              span Albumes: <span id="countAlbumes">0</span>

          .card.mb-1.p-1(style="background-color: #d9cbb6")
            h6.text-center Crear publicación
            br
            #formPublicacionContainer

          .card.p-3
            h6.text-center 
              i.bi.bi-people-fill
              |  Seguidores: (
              span#seguidoresContador 0
              | )
              br
            ul#amigos-list

        // IZQUIERDA: Amigos + Búsqueda


        // CENTRO: Timeline
        .col-md-6
          h5.mb-4.text-center Todas las Noticias:   </i> <i class="bi bi-camera2"></i> <i class="bi bi-chat-left-text-fill"></i>

          // Barra de búsqueda
          form#formBusqueda(action="/buscar" method="GET" class="mb-3 d-flex justify-content-center")
            input.form-control(type="text" name="query" placeholder="Buscar por #Tags, Usuarios o Imagenes..." style="max-width: 400px;")
            button.btn.btn-primary.ms-2(type="submit") Buscar

          #publicaciones


    // TOAST
    #toastContainer.position-fixed.bottom-0.end-0.p-3(style="z-index: 9999")
      #respuestaToast.toast(role="alert" aria-live="assertive" aria-atomic="true")
        .toast-header
          strong.me-auto Notificación
          small.text-muted ahora
          button.btn-close(type="button" data-bs-dismiss="toast")
        .toast-body
          span#toastMessage Aquí se mostrará la respuesta a tu solicitud


    // Modal Denuncia
    div#modalDenuncia.modal.fade(tabindex="-1" aria-labelledby="modalDenunciaLabel" aria-hidden="true")
      div.modal-dialog.modal-dialog-centered
        div.modal-content.custom-modal-color
          form#formDenuncia
          div.modal-header
            h5#modalDenunciaLabel.modal-title Denunciar contenido
            button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Cerrar")
          div.modal-body
            input(type="hidden" id="denunciaTipo" name="tipo")
            input(type="hidden" id="denunciaId" name="elementoId")
            label(for="motivo") Motivo de la denuncia
            select#motivo.form-select
              option(value="contenido_ofensivo") Contenido ofensivo
              option(value="spam") Spam o publicidad no deseada
              option(value="contenido_inapropiado") Contenido inapropiado
              option(value="otro") Otro
            label.mt-2(for="detalle") Detalle (opcional)
            textarea#detalle.form-control(rows="3" placeholder="Describe el problema o agrega detalles adicionales...")
            <br>
            span#mensajeDenuncia.text-success.d-none.mt-2
          div.modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
            button#btnConfirmarDenuncia.btn.btn-danger(type="button") Enviar denuncia


    // SCRIPTS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    script(src="/socket.io/socket.io.js")
    script(src="/js/inicio.js")
    script(src="/js/navbar.js")
    script(src="/js/seguidores.js")
