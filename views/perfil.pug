

doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Mi Perfil - Artesanos.com

    //- Bootstrap y estilos externos
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap")
    link(rel="stylesheet", href="/css/dashboard.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
    link(rel="stylesheet", href="/css/perfil.css")
    link(rel="icon", href="/uploads/icon.png", type="image/png")
    
    

  body
    include includes/navbar.pug

    .container.mt-5
      .text-center
        img#avatar(src="/uploads/default-avatar.png", alt="Avatar", class="rounded-circle mb-3", style="width: 140px; height: 140px; object-fit: cover;")
        h2.mt-2
          span#nombreCompleto Nombre Apellido
        p.text-muted#email correo@ejemplo.com
        <p class="text-muted">Última conexión: <span id="ultima_conexion">No disponible</span></p>


        

      hr

      .row.mt-4
        .col-md-6
          h4 Intereses
          p#intereses No especificado
        .col-md-6
          h4 Antecedentes
          p#antecedentes No especificado

      hr

      h4.text-center.mt-5 Estadísticas

      .row.text-center.mt-4
        .col-md-3
          .estadistica-box
            h5 Imágenes subidas
            p.fs-4.mb-0#total_imagenes 0
        .col-md-3
          .estadistica-box
            h5 Publicaciones con foto
            p.fs-4.mb-0#total_publicaciones 0
        .col-md-3
          .estadistica-box
            h5 Seguidos
            p.fs-4.mb-0#total_seguidos 0
        .col-md-3
          .estadistica-box
            h5 Seguidores
            p.fs-4.mb-0#total_seguidores 0
        

      .row.text-center.mt-4
        .col-md-3
          .estadistica-box
            h5 Álbumes publicados
            p.fs-4.mb-0#total_albumes 0
        
        .col-md-3
          .estadistica-box
            h5 Comentarios hechos
            p.fs-4.mb-0#total_comentarios 0
        .col-md-3
          .estadistica-box
            h5 Comentarios recibidos
            p.fs-4.mb-0#comentarios_hechos 0
        .col-md-3
          .estadistica-box
            h5 Tiempo en plataforma (días)
            p.fs-4.mb-0#tiempo_en_plataforma  0 

        a.navbar-brand(href="/dashboard") Artesanos.com

    //-   .row.text-center.mt-4
    //-     .col-md-3.offset-md-9
    //-       .estadistica-box
    //-         h5 Última conexion
    //-         p.fs-4.mb-0#ultima_conexion No disponible

            

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    script(src="/js/perfil.js")
